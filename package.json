{
  "name": "pika",
  "version": "1.0.0",
  "main": "dist-electron/electron/main.js",
  "description": "AI-powered interview copilot and meeting assistant.",
  "scripts": {
    "clean": "rimraf dist dist-electron",
    "dev": "vite",
    "build": "pnpm run clean && tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "postinstall": "cross-env SHARP_IGNORE_GLOBAL_LIBVIPS=1 pnpm rebuild sharp && node scripts/download-models.js && node scripts/ensure-sqlite-vec.js",
    "electron:dev": "pnpm run build:electron && cross-env NODE_ENV=development electron .",
    "electron:build": "pnpm run build:electron && cross-env NODE_ENV=production electron .",
    "app:dev": "concurrently \"pnpm run dev -- --port 5180 --strictPort\" \"wait-on http://localhost:5180 && pnpm run electron:dev\"",
    "app:prod": "pnpm run build && pnpm run build:electron && pnpm run build:native && cross-env NODE_ENV=production electron .",
    "app:build": "pnpm run build && pnpm run build:electron && pnpm run build:native && electron-builder --publish never",
    "watch": "tsc -p electron/tsconfig.json --watch",
    "start": "pnpm run app:dev",
    "dist": "pnpm run app:build",
    "icons:generate": "node generate_icon.js",
    "build:native": "node scripts/build-native.js",
    "test": "tap --node-arg=--import=tsx \"test/**/*.test.ts\""
  },
  "build": {
    "generateUpdatesFilesForAllChannels": true,
    "appId": "com.royisme.pika",
    "afterPack": "./scripts/ad-hoc-sign.js",
    "productName": "Pika",
    "files": [
      "dist",
      "dist-electron",
      "native-module",
      "node_modules",
      "package.json",
      "!**/native-module/target",
      "!**/native-module/src",
      "!**/native-module/.cargo",
      "!**/node_modules/**/{test,tests,__tests__,__mocks__,example,examples,docs,.github}",
      "!**/node_modules/**/*.{md,ts,map}",
      "!**/node_modules/.package-lock.json"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.dylib"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      },
      {
        "from": "resources/models/",
        "to": "models/"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/pika.icns",
      "identity": "shaoqing zhu (UL5T9WXYJT)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/win/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/png/",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": null
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pnpm": {
    "overrides": {
      "caniuse-lite": "1.0.30001781"
    }
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.3",
    "@napi-rs/cli": "^3.5.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/color": "^4.2.0",
    "@types/diff": "^6.0.0",
    "@types/electron": "^1.4.38",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/screenshot-desktop": "^1.12.3",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.2",
    "electron-is-dev": "^3.0.1",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@bany/curl-to-json": "^1.2.10",
    "@elevenlabs/client": "^0.15.1",
    "@elevenlabs/elevenlabs-js": "^2.39.0",
    "@google-cloud/speech": "^7.2.1",
    "@google/genai": "^1.44.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.2",
    "@tavily/core": "^0.7.2",
    "@types/keytar": "^4.4.0",
    "@types/three": "^0.182.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.7.7",
    "better-sqlite3": "12.6.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "diff": "^7.0.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.7.3",
    "form-data": "^4.0.1",
    "framer-motion": "^12.29.2",
    "groq-sdk": "^0.37.0",
    "jspdf": "^4.0.0",
    "katex": "^0.16.27",
    "keytar": "^7.9.0",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.11.0",
    "openai": "^6.22.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-code-blocks": "^0.1.6",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0",
    "react-markdown": "^10.1.0",
    "react-query": "^3.39.3",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "screenshot-desktop": "^1.15.0",
    "sharp": "^0.33.5",
    "sqlite-vec": "^0.1.7",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^2.5.4",
    "tap": "^21.5.0",
    "tesseract.js": "^5.0.5",
    "three": "^0.182.0",
    "tree-kill": "^1.2.2",
    "uuid": "^11.0.3",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "sqlite-vec-darwin-arm64": "^0.1.7"
  }
}
